# Symgov backend database configuration only
#
# Runtime path:
# Use the least-privilege app role for normal backend reads and writes.
# Replace <password-from-/docker/symgov-postgres/.env> with the value stored in:
#   SYMGOV_APP_PASSWORD
SYMGOV_DATABASE_URL=postgresql://symgov_app:<password-from-/docker/symgov-postgres/.env>@symgov-postgres:5432/symgov

# Connection pool sizing
SYMGOV_DB_POOL_SIZE=10
SYMGOV_DB_MAX_OVERFLOW=10

# Migration path:
# Use the migrator role only for schema migration commands, not for normal app runtime.
# The backend should keep SYMGOV_DATABASE_URL pointed at symgov_app.
# Replace <password-from-/docker/symgov-postgres/.env> with the value stored in:
#   SYMGOV_MIGRATOR_PASSWORD
# Example migration URL:
# postgresql://symgov_migrator:<password-from-/docker/symgov-postgres/.env>@symgov-postgres:5432/symgov
