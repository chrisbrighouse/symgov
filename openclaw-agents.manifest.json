        "profile": "full",
        "allow": [
          "group:runtime",
          "group:sessions"
        ],
        "elevated": {
          "enabled": true,
          "allowFrom": {
            "telegram": [
              7643191699
            ]
          }
        }
      },
      "agent_to_agent": true,
