{
  "version": 1,
  "safe_plugins": {
    "allow": [
      "telegram",
      "discord",
      "acpx",
      "browser",
      "openai",
      "anthropic",
      "google",
      "memory-core"
    ],
    "disable": [
      "googlechat",
      "nostr",
      "slack"
    ]
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "libby",
