{
  "version": 1,
  "safe_plugins": {
    "allow": [
      "telegram",
      "discord",
      "acpx",
      "browser",
      "openai",
      "anthropic",
      "google",
      "memory-core"
    ],
    "disable": [
      "googlechat",
      "nostr",
      "slack"
    ]
  },
  "model_profiles": {
    "fast": {
      "model": "openai/gpt-5-mini",
      "description": "Low-latency default for intake, routing, and coordination work."
    },
    "deep_reasoning": {
      "model": "openai/gpt-5.2",
      "description": "Higher-capability reasoning for release and governance decisions."
    },
    "vision": {
      "model": "google/gemini-3.1-pro-preview",
      "description": "Vision-capable analysis for graphical symbol validation and raster inspection."
    },
    "research": {
      "model": "openai/gpt-5.3-codex",
      "description": "Research-heavy provenance, curation, and intelligence tasks."
    },
    "classification": {
      "model": "anthropic/claude-sonnet-4-6",
      "description": "Classification, taxonomy, and symbol metadata reasoning tasks."
    },
    "design": {
      "model": "openai/gpt-5.2",
      "description": "Interface, documentation, copy, and experience review tasks."
    }
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "libby",
      "match": {
        "channel": "telegram",
        "accountId": "7643191699"
      }
    }
  ],
  "agents": [
    {
      "id": "scott",
      "name": "Scott",
      "workspace": "/data/.openclaw/workspaces/scott",
      "agent_dir": "/data/.openclaw/agents/scott/agent",
      "model_profile": "fast",
      "identity_name": "Scott",
      "tools": {
        "profile": "full",
        "allow": [
          "group:runtime",
          "group:sessions"
        ],
        "elevated": {
          "enabled": true,
          "allowFrom": {
            "telegram": [
              7643191699
            ]
          }
        }
      },
      "agent_to_agent": true,
      "required_workspace_files": [
        "AGENTS.md",
        "IDENTITY.md",
